generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   @map("password_hash")
  googleId      String?   @map("google_id")
  role          String    @default("user") // 'user' | 'admin'
  timezone      String    @default("Asia/Tokyo")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  subscription  Subscription?
  usageDaily    UsageDaily[]
  brandKit      BrandKit?
  jobs          GenerationJob[]
  auditLogs     AuditLog[]
  
  @@map("User")
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique @map("user_id")
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  status                String    // 'active' | 'past_due' | 'canceled' | 'incomplete'
  planId                String?   @map("plan_id")
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("Subscription")
}

model UsageDaily {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date // JST基準の日付
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId, date])
  @@map("UsageDaily")
}

model BrandKit {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  logoUrl        String?  @map("logo_url")
  primaryColor   String?  @map("primary_color") // #RRGGBB
  secondaryColor String?  @map("secondary_color")
  fontMood       String?  @map("font_mood") // 'modern' | 'traditional' | 'playful' | 'elegant'
  ngWords        String[] @map("ng_words")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("BrandKit")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  
  templates Template[]
  
  @@map("Category")
}

model Template {
  id           String   @id @default(cuid())
  categoryId   String   @map("category_id")
  name         String
  description  String?
  basePrompt   String   @map("base_prompt") @db.Text
  layoutPrompt String?  @map("layout_prompt") @db.Text
  defaultTone  String?  @map("default_tone")
  sizes        String[] // ['1080x1080', '1200x628']
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  category Category @relation(fields: [categoryId], references: [id])
  jobs     GenerationJob[]
  
  @@map("Template")
}

model GenerationJob {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  templateId   String?   @map("template_id")
  status       String    // 'pending' | 'processing' | 'completed' | 'failed'
  inputData    Json      @map("input_data") // {category, size, keyword, purpose, tone}
  finalPrompt  String?   @map("final_prompt") @db.Text
  size         String
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")
  
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id])
  assets   Asset[]
  
  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("GenerationJob")
}

model Asset {
  id         String   @id @default(cuid())
  jobId      String   @map("job_id")
  variant    String   // 'A' | 'B' | 'C'
  storageKey String   @map("storage_key")
  url        String
  fileSize   Int?     @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at")
  
  job GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  @@index([jobId])
  @@map("Asset")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  
  user User? @relation(fields: [userId], references: [id])
  
  @@index([userId, createdAt(sort: Desc)])
  @@map("AuditLog")
}

