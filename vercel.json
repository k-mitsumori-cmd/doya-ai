{
  "framework": "nextjs",
  "buildCommand": "prisma generate && node ./scripts/db-push-if-db-url.mjs && next build",
  "functions": {
    "src/app/api/adsim/projects/[projectId]/export/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "src/app/api/adsim/projects/[projectId]/banners/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/adsim/auto-generate/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/adsim/projects/[projectId]/proposal/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/monthly-summary",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/gcp-usage",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/drip-sender",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/drip-report-morning",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/drip-report-evening",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/aio-scan",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/analytics-report",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/appstore-report",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/appstore-marketing-report",
      "schedule": "5 1 * * *"
    },
    {
      "path": "/api/cron/noroi-engagement-report",
      "schedule": "10 1 * * *"
    },
    {
      "path": "/api/cron/appstore-country-report",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/cron/noroi-weekly-summary",
      "schedule": "20 1 * * 1"
    },
    {
      "path": "/api/cron/noroi-monthly-summary",
      "schedule": "25 1 1 * *"
    },
    {
      "path": "/api/cron/yurusen-appstore-report",
      "schedule": "30 1 * * *"
    }
  ]
}
